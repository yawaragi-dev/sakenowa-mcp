{
  "name": "@yawaragi/sakenowa-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server exposing read-only tools over a Sakenowa-mirrored Postgres of Japanese sake data.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sake",
    "sakenowa",
    "japanese-sake"
  ],
  "author": "Borys Vengerov",
  "license": "MIT",
  "packageManager": "pnpm@11.3.0",
  "type": "module",
  "bin": {
    "sakenowa-mcp": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yawaragi-dev/sakenowa-mcp.git"
  },
  "homepage": "https://github.com/yawaragi-dev/sakenowa-mcp#readme",
  "bugs": {
    "url": "https://github.com/yawaragi-dev/sakenowa-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run integration.test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "pg": "^8.13.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testcontainers/postgresql": "^10.16.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "eslint": "^9.17.0",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.0"
  }
}
